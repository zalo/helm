# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
dist/
dist-ssr/
*.local
.vite/

# Env / secrets
.env
.env.*
!.env.example
helm.config.local.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Helm runtime artifacts.
#
# Convention for ANY analysis the engine or an agent generates at runtime
# (risk analyses, backtest results, trade journals, snapshots, scenario
# reports, factor models, correlation matrices, …): write it under
# `backend/data/<kind>/<id>.json`. Everything below that path is ignored.
#
# Committed examples ship under `backend/helm/data_seed/<kind>/` and are
# NOT ignored — that's where seed fixtures + canonical schemas live.
backend/data/
*.log

# Output dirs that agent scripts may write into.
backend/scripts/output/
backend/scripts/.cache/

# Catch-all for analysis-style folders created anywhere in the tree.
**/analyses/
**/reports/
**/journal/
**/snapshots/

# Common generated-artifact file types. Anything legitimately committed
# under those extensions should live in a `data_seed/` dir or be added
# with `git add -f`.
*.parquet
*.pdf
*.html.tmp
*.csv.tmp

# Agent CLI chat ring buffer (disk-backed history for the Chat panel).
.chat_history.json
backend/.chat_history.json

# Position-watcher threshold config (per-user, contains current holdings).
.watcher.json
backend/.watcher.json

# Per-user OpenBB virtualenv — should be created locally, never committed.
openbb-venv/

# `npx skills add` artifacts. SKILL.md files under .agents/skills/ are the
# installed-skill bodies; skills-lock.json is the install manifest.
.agents/
skills-lock.json

# Project-scope Claude Code settings live at repo-root .claude/.
# `backend/.claude/` is a stray duplicate from running `helm-agent install`
# while cwd was backend/ — ignore so it doesn't get re-tracked.
backend/.claude/
