.agents/
skills-lock.json

# Project-scope Claude Code settings live at repo-root .claude/.
# `backend/.claude/` is a stray duplicate from running `helm-agent install`
# while cwd was backend/ — ignore so it doesn't get re-tracked.
backend/.claude/
