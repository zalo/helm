# Helm backend configuration. Copy to `.env` and edit. All vars are HELM_-prefixed.
# Out of the box Helm runs in demo mode with zero credentials.

# --- Engine mode: demo | sandbox | live | backtest ---
# demo     = built-in market + AI-trader simulator (no credentials needed)
# sandbox  = real Nautilus node, simulated execution against live market data
# live     = real Nautilus node, real venue execution (requires credentials)
HELM_MODE=demo

HELM_TRADER_ID=HELM-001
HELM_STARTING_EQUITY=100000
HELM_BASE_CURRENCY=USD

# How often the AI trader re-evaluates (seconds)
HELM_AI_TICK_SECONDS=8
HELM_AI_AUTOSTART=true

# --- Venue credentials (only used when HELM_MODE != demo) ---
# Binance
# HELM_BINANCE_API_KEY=
# HELM_BINANCE_API_SECRET=
# Interactive Brokers (TWS / IB Gateway must be running)
# HELM_IB_HOST=127.0.0.1
# HELM_IB_PORT=7497
# HELM_IB_CLIENT_ID=1

# --- OpenBB research layer (optional) ---
# Run an OpenBB Platform REST server and point Helm at it for news/fundamentals/macro.
# Helm only talks to OpenBB over HTTP — it never imports the AGPL package.
# HELM_OPENBB_API_URL=http://localhost:6900
# HELM_OPENBB_PAT=

# --- HTTP ---
# HELM_FEED_CACHE_TTL_S=300
